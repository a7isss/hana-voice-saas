# ============================
# Hana Voice SaaS Environment Variables
# Copy this to .env and fill in values
# ============================

# --- Database Configuration ---
# PostgreSQL connection string (provided by Render)
DATABASE_URL=postgresql://hana_user:password@database-host:5432/hana_voice_db

# --- AI Services ---
# OpenAI API Key (for TTS and STT)
OPENAI_API_KEY=sk-your-openai-api-key-here

# --- Authentication ---
# JWT Secret Key (generate with: openssl rand -hex 32)
JWT_SECRET_KEY=generate-random-32-byte-hex-string

# --- Application Settings ---
# Environment (development/production)
ENVIRONMENT=development
HOST=0.0.0.0
PORT=8000
DEBUG=true

# --- Render-Specific (set automatically) ---
# These are set by Render deployment:
# RENDER_SERVICE_ID
# RENDER_DEPLOY_HOOK_URL
# RENDER_APP_URL

# ============================
# LOCAL DEVELOPMENT SETUP
# ============================

# For local PostgreSQL database (optional):
# docker run -d --name hana-postgres -p 5432:5432 -e POSTGRES_PASSWORD=dev_password -e POSTGRES_DB=hana_dev postgres:15
# DATABASE_URL=postgresql://postgres:dev_password@localhost:5432/hana_dev

# For local development without OpenAI (limited functionality):
# OPENAI_API_KEY=
# (Audio generation won't work, but other features will)
