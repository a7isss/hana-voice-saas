{
  "project": {
    "name": "Hana Voice Robot SaaS",
    "version": "3.0.0",
    "description": "AI-powered patient experience survey system for healthcare providers",
    "architecture": "Microservices Docker Containerized"
  },

  "components": {

    "backend-api": {
      "location": "src/",
      "language": "Python 3.11",
      "framework": "FastAPI",
      "purpose": "Main REST API server with business logic",
      "connects_to": [
        "database",
        "freepbx-container",
        "speech-services",
        "dashboard-frontend"
      ],
      "key_files": [
        "main.py - Application entry point with FastAPI app",
        "src/core/ai_agent.py - AI conversation logic",
        "src/core/stt_tts.py - Speech processing",
        "src/config/client_manager.py - Multi-client configuration",
        "src/survey/engine.py - Questionnaire logic",
        "src/storage/database.py - PostgreSQL ORM models",
        "src/dashboard/reporting.py - Analytics endpoints",
        "src/telephony/ - Phone call management system"
      ],
      "configuration": {
        "environment_vars": [
          "DATABASE_URL",
          "FREE_PBX_HOST",
          "FREE_PBX_USERNAME",
          "FREE_PBX_PASSWORD",
          "DEBUG",
          "HOST",
          "PORT"
        ],
        "ports": ["8000"],
        "health_checks": ["/health"]
      }
    },

    "database": {
      "location": "N/A (Docker container)",
      "technology": "PostgreSQL 15 Alpine",
      "purpose": "Persistent data storage for clients, surveys, calls",
      "connects_to": [
        "backend-api",
        "dashboard-frontend (indirectly via API)"
      ],
      "configuration": {
        "environment_vars": [
          "POSTGRES_DB=hana_v3",
          "POSTGRES_USER=postgres",
          "POSTGRES_PASSWORD=password"
        ],
        "ports": ["5432"],
        "volumes": ["postgres_data"]
      },
      "schemas": [
        "survey_responses - Patient answers",
        "call_logs - Call history and status",
        "client_data - Multi-tenant client information"
      ]
    },

    "freepbx-container": {
      "location": "N/A (Docker container)",
      "technology": "FreePBX/Asterisk",
      "purpose": "Telephony server for outbound calls and IVR",
      "connects_to": [
        "backend-api",
        "external-telephone-network"
      ],
      "configuration": {
        "ports": [
          "5080 (Web UI)",
          "5433 (Secure Web)",
          "5060/udp (SIP)",
          "18000-18100/udp (RTP)"
        ],
      "environment_vars": [
        "DB_EMBEDDED=TRUE",
        "ASTERISK_VER=18",
        "TZ=Asia/Riyadh",
        "ENABLE_SMTP=TRUE",
        "DEBUG_MODE=TRUE"
      ],
        "volumes": [
          "freepbx_data",
          "freepbx_logs",
          "freepbx_sounds"
        ],
        "credentials": {
          "web_ui": "admin/admin",
          "container_default": "admin/password"
        }
      }
    },

    "dashboard-frontend": {
      "location": "dashboard/",
      "language": "JavaScript React",
      "framework": "React 18 + Material-UI",
      "purpose": "Modern Arabic interface for system monitoring and management",
      "connects_to": [
        "backend-api"
      ],
      "key_files": [
        "dashboard/package.json - Dependencies and scripts",
        "dashboard/src/App.js - Main application with RTL theme",
        "dashboard/src/pages/Dashboard.js - KPI overview",
        "dashboard/src/pages/Reports.js - Analytics reports",
        "dashboard/src/pages/Calls.js - Call management interface",
        "dashboard/src/pages/Settings.js - System configuration"
      ],
      "configuration": {
        "proxy": "http://localhost:8000",
        "rtl_support": true,
        "arabic_fonts": "Cairo font family",
        "responsive_design": true
      }
    },

    "configuration-system": {
      "location": "config/",
      "purpose": "Centralized configuration management",
      "files": [
        "config/telephony.json - Telephony provider settings",
        "config/clients/ - Client-specific configurations",
        "config/surveys/ - Questionnaire templates",
        ".env.example - Environment variable templates"
      ],
      "connects_to": [
        "backend-api",
        "freepbx-container"
      ]
    },

    "containerization": {
      "location": "root level",
      "purpose": "Docker orchestration for development and production",
      "files": [
        "Dockerfile - Python FastAPI container build",
        "docker-compose.yml - Development environment",
        "docker-compose.prod.yml - Production deployment"
      ],
      "networks": [
        "hana-network (internal container communication)"
      ]
    },

    "debugging-system": {
      "location": ".vscode/",
      "purpose": "Development environment setup and debugging",
      "files": [
        ".vscode/launch.json - VS Code debug configurations",
        "setup.sh - Quick setup script"
      ],
      "configuration": {
        "debug_py_port": 5678,
        "api_port": 8000,
        "remote_debugging": {
          "host": "localhost",
          "pathMappings": ["${workspaceFolder}:/app"]
        }
      }
    }
  },

  "data_flow": {
    "user_interaction": [
      "Dashboard Frontend → FastAPI Backend → Database",
      "VS Code Debug → debugpy on port 5678 → Python application",
      "FreePBX Web UI → Direct configuration"
    ],

    "call_process": [
      "API receives call request → Connects to FreePBX → FreePBX makes call",
      "Call status updates → Webhooks → API updates database",
      "AI conversation logic → Speech processing → Survey responses"
    ],

    "telephony_integration": [
      "Backend API → FreePBX AMI interface → Asterisk PBX",
      "Configuration: Host/Container networking → SIP trunk setup",
      "Call workflow: Initiation → Status webhooks → Result storage"
    ]
  },

  "development_workflow": {
    "local_development": [
      "docker-compose up → Start all services",
      "cd dashboard && npm start → Launch frontend",
      "VS Code F5 → Attach debugger to backend",
      "FreePBX UI at localhost:5080 for telephony setup"
    ],

    "testing_workflow": [
      "Unit tests: pytest in src/tests/",
      "Integration tests: Full container testing with test calls",
      "API testing: Swagger UI at /docs",
      "Database testing: Direct PostgreSQL connections"
    ],

    "deployment_workflow": [
      "Production build: docker-compose.prod.yml",
      "CI/CD: Automated builds and security scans",
      "Monitoring: Health checks and log aggregation",
      "Backup: Database and configuration preservation"
    ]
  },

  "potential_conflicts": {
    "environment_variables": [
      "Ensure .env variables match Docker compose settings",
      "FREE_PBX_HOST must be 'freepbx' in container, external IP in external setup",
      "Database URL consistency across all components"
    ],

    "port_mappings": [
      "Local development: 8000, 5432, 5080, 5678",
      "Production: May need different external mappings",
      "Conflict possible with existing services on host"
    ],

    "file_permissions": [
      "Docker volumes must have correct permissions",
      "Configuration files mounted from host to container",
      "Service account files for Google APIs"
    ]
  },

  "testing_checklist": {
    "container_integrity": [
      "docker-compose build completes without errors",
      "All services start successfully",
      "Health checks pass for all services",
      "Network connectivity between containers"
    ],

    "api_functionality": [
      "/health endpoint responds correctly",
      "Client management endpoints work",
      "Dashboard reporting endpoints return data",
      "Test call endpoint can trigger FreePBX"
    ],

    "frontend_integration": [
      "Build process completes successfully",
      "API calls from frontend succeed",
      "Arabic RTL rendering works correctly",
      "Responsive design functions on different screen sizes"
    ],

    "telephony_integration": [
      "FreePBX web UI accessible",
      "AMI connection established",
      "Outbound call capability verified",
      "Call status webhooks functional"
    ]
  }
}
