# Hana Voice SaaS - Environment Configuration
# Copy this file to .env and fill in your actual values

# API Service Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-in-production
API_SERVICE_PORT=8000

# Voice Service Configuration
VOICE_SERVICE_PORT=8001
OPENAI_API_KEY=your-openai-api-key-here

# Data Service Configuration
DATA_SERVICE_PORT=8002

# Supabase Configuration
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key

# FreePBX Telephony Configuration
FREEPBX_HOST=your-freepbx-server-host
FREEPBX_USERNAME=your-ami-username
FREEPBX_PASSWORD=your-ami-password
FREEPBX_PORT=5038

# Frontend Configuration
NEXT_PUBLIC_API_URL=http://localhost:8000

# Application Settings
ENVIRONMENT=development
LOG_LEVEL=INFO

# Saudi-Specific Settings
DEFAULT_LANGUAGE=ar
DEFAULT_VOICE=nova
DEFAULT_SPEED=0.95
BUSINESS_HOURS_START=08:00
BUSINESS_HOURS_END=22:00
TIMEZONE=Asia/Riyadh
